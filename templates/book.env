# ── 책 설정 (book.env) ───────────────────────────────────────
# "키=값" 형식. 값에 공백/한글이 있으면 큰따옴표로 감싼다.
# 이 파일만 채우면 추출·표지·빌드가 모두 이 값으로 동작한다.

# ── 기본 정보 ───────────────────────────────────────────────
TITLE="○○ 강해"            # 책 제목 (표지·메타데이터)
BOOK_NAME="○○"             # 성경책 이름 (표지 큰 글자)
AUTHORS="조춘숙"            # 지은이
AUTHOR_TITLE="목사"        # 직함
PUBLISHER="물줄기교회 출판부"
LANGUAGE="ko"
OUTPUT_NAME="○○ 강해"      # 출력 파일명 베이스 (비우면 TITLE 사용)
TAGS="기독교,설교,강해"     # 분류 태그 (쉼표 구분)
COMMENTS="물줄기교회 조춘숙 목사 ○○ 강해 설교집."

# ── 버전 관리 ───────────────────────────────────────────────
EDITION="제1판"            # 판 (큰 개정 시 올림)
VERSION="1.0.0"            # 세부 버전 (오탈자/디자인 수정)
RELEASE_DATE="2026-01"     # 발행일 YYYY-MM 또는 YYYY-MM-DD

# ── 검토 ─────────────────────────────────
# 출판 전 원고 검토 완료 시 yes. (review.py + docs/검토체크리스트.md)
REVIEWED=""
REVIEW_DATE=""


# ── 추출용 ──────────────────────────────────────────────────
HWP_SOURCE="original/원본파일.hwp"   # original/ 안의 HWP 파일명
BIBLE_REF="○○"            # 본문 성경책 이름 (장 구절 인식용, 보통 BOOK_NAME과 같음)
VIDEO="동영상 설교는 https://vimeo.com/watercourse 또는 YouTube에서 “물줄기교회”를 검색해 주세요."
PREFACE_SIGN="2026년 1월|물줄기교회 목사 조춘숙"   # 머리말 서명 (| 로 줄바꿈)
# 판권 항목 (| 로 줄바꿈). 판/발행일/버전은 위 값에서 자동 생성되니 여기 넣지 말 것.
COLOPHON="지은이  조춘숙 목사|제작·편집  물줄기교회 출판부|주소  서울 강서구 수명로 68-27 웨스트엔드 2차 문화센터 4층|전화  02-6403-3221|홈페이지  https://vimeo.com/watercourse"

# ── 표지 ────────────────────────────────────────────────────
COVER_VERSE="대표 구절 1행|대표 구절 2행|○○ 5장 4절"  # 마지막 칸은 출처
COVER_BG="1c3144"          # 배경색 (hex)
COVER_ACCENT="c9a25a"      # 강조색 (hex)
